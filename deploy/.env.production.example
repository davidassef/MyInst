# ================================================================================
# MyInst — Variáveis de Produção (VPS)
# Copie para .env e preencha os valores
# ================================================================================

# Database (shared-postgres na rede shared-infra-net)
DB_USER=myinst_user
DB_PASSWORD=TROCAR_POR_SENHA_SEGURA

# JWT
JWT_SECRET=TROCAR_POR_SECRET_LONGO_ALEATORIO

# Domínio de produção
# Exemplo: APP web em myinst.lotoscore.com.br e API em api-myinst.lotoscore.com.br
APP_URL=https://myinst.seudominio.com
API_PUBLIC_URL=https://api-myinst.seudominio.com
CORS_ORIGIN=https://myinst.seudominio.com
WEB_OAUTH_SUCCESS_URL=https://myinst.seudominio.com/login

# OAuth (opcional — deixe vazio para desabilitar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_URL=https://api-myinst.seudominio.com

# Frontend/Deploy
VITE_MYINST_API_BASE=https://api-myinst.seudominio.com

# Shared Infra (usado pelo docker-compose.shared-infra.yml)
POSTGRES_PASSWORD=TROCAR_POR_SENHA_POSTGRES_ROOT
REDIS_PASSWORD=TROCAR_POR_SENHA_REDIS
